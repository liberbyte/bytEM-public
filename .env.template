# BytEM Configuration - Hybrid Instance (Supply + Demand + Exchange)
# Instance Configuration
NODE_ENV=production
BYTEM_INSTANCE=bytem

# ============================================================================
# INTERNAL SERVICES — PUBLIC DOMAIN (bm3 architecture)
# ============================================================================
# .env holds the real multi-machine domain URLs (used in production when
# each service is on its own server, or in non-Docker local dev).
#
# For the Docker stack, docker-compose.yaml OVERRIDES these with Docker
# container names in each service's `environment:` block — same pattern as
# POSTGRES_HOST being overridden to `bytem-synapse-db` for Synapse.
#
# Non-Docker / local dev: keep the domain URLs or switch to localhost variants.

# Matrix/Synapse Server (Internal)
# Non-Docker: MATRIX_SERVER=https://matrix.bytem.alpha.cities.app
MATRIX_SERVER=https://matrix.${BYTEM_DOMAIN}
MATRIX_SERVER_NAME=matrix.${BYTEM_DOMAIN}
MATRIX_SERVER_PROTOCOL=https
MATRIX_PORT=8008
MATRIX_SSO_CALLBACK_URL=https://matrix.${BYTEM_DOMAIN}/auth/matrix/callback


# SSL Configs
# DOMAIN_NAME is read by the seed scripts (test/*.py) via BYTEM_DOMAIN; not dead.
DOMAIN_NAME=${BYTEM_DOMAIN}
# Index Room (derived: #<BYTEM_INSTANCE>-index-room:<MATRIX_SERVER_NAME>)
SUPPLY_INDEX_ROOM_ALIAS="#bytem-supply-index-room:matrix.${BYTEM_DOMAIN}"
DEMAND_INDEX_ROOM_ALIAS="#bytem-demand-index-room:matrix.${BYTEM_DOMAIN}"

# API Gateway
# Docker:     overridden to http://bytem-be:3000 in docker-compose.yaml
# Non-Docker: API_HOST_INTERNAL=http://localhost:3000
API_HOST=https://${BYTEM_DOMAIN}
API_HOST_INTERNAL=http://localhost:3000
EXCHANGE_PORT=3000

# Frontend App (Internal)
APP_SERVER=https://${BYTEM_DOMAIN}
APP_PORT=8000

# RabbitMQ
# Docker:     overridden to amqp://bytem-rabbitmq:5672/bytem in docker-compose.yaml
# Non-Docker: RABBITMQ_URL=amqp://localhost:5672/bytem
RABBITMQ_URL=amqp://${BYTEM_DOMAIN}:5672/bytem

# Apache Solr
# Docker:     overridden to http://bytem-solr:8983 in docker-compose.yaml
# Non-Docker: SOLR_URL=http://127.0.0.1:8983
SOLR_URL=http://${BYTEM_DOMAIN}:8983
SOLR_USER=solr
SOLR_PASSWORD=${SOLR_PASSWORD}

# Bot Service (Internal)
BOT_PORT=4000

# ============================================================================
# EXTERNAL/PUBLIC CONFIGURATION (Environment-Specific)
# ============================================================================
# These are used for federation and external communication
# Change these based on your deployment (bm3, bm10, etc.)

# Public Exchange Server Hostname (for Federation)
EXCHANGE_SERVER_PROTOCOL=https

# Matrix Federation Settings
FEDERATION_ENABLED=true

# Matrix User IDs (use public domain for federation)
MATRIX_ADMIN_USER=@test:matrix.${BYTEM_DOMAIN}

# ============================================================================
# CREDENTIALS & AUTHENTICATION
# ============================================================================

# Bot Credentials
BOT_USERNAME=bot
BOT_PASSWORD=${BOT_PASSWORD}
BOT_USER_ID=@bot:matrix.${BYTEM_DOMAIN}
BOT_USER_ACCESS_TOKEN=${BOT_USER_ACCESS_TOKEN}


# Matrix SSO Configuration
MATRIX_SSO_ENABLED=true
MATRIX_SSO_CLIENT_ID=test

# Matrix Admin Configuration
SYNAPSE_ADMIN_TOKEN=${BOT_USER_ACCESS_TOKEN}
MATRIX_ADMIN_USERNAME=bot
MATRIX_ADMIN_PASSWORD=${BOT_PASSWORD}

# RabbitMQ Credentials
RABBITMQ_DEFAULT_USER=${RABBITMQ_DEFAULT_USER}
RABBITMQ_DEFAULT_PASS=${RABBITMQ_DEFAULT_PASS}
RABBITMQ_DEFAULT_VHOST=bytem

# PostgreSQL
# Non-Docker: POSTGRES_HOST=localhost
POSTGRES_HOST=localhost
POSTGRES_USER=synapse
POSTGRES_PASSWORD=${SYNAPSE_POSTGRES_PASSWORD}
SYNAPSE_POSTGRES_PASSWORD=${SYNAPSE_POSTGRES_PASSWORD}

# SSL
SSL_EMAIL=admin@${BYTEM_DOMAIN}

# Application Secrets
JWT_SECRET=${JWT_SECRET}

# Logging (set to false in production to silence log/warn/debug; errors always show)
ENABLE_LOGGING=true

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# App Configuration
NODE_MODE=demand-supply

# External URLs
DOMAIN_LIST=https://bytem.app/domains/domain-list

# Schema URLs
BYTEM_SCHEMA_URL=https://bytem.app/schema/

# File Configs
MAX_FILE_SIZE=52428800

# PWA-specific runtime values are DERIVED in docker-compose.yaml from
# API_HOST and MATRIX_SERVER (single source of truth). See bytem-pwa service.
# Vars consumed by pwa/app/config.ts and pwa/public/config.js:
#   NEXT_PUBLIC_API_BASE_URL, PWA_URL, PWA_BYTEM_DEMROOM_FRAME_BACKLINK,
#   PWA_DEMAND_BYTEM_GUEST, PWA_MATRIX_BYTEM_URL

# Synapse stable secret keys (preserved across container restarts). No need to generate new on each restart or all tokens become invalidated
SYNAPSE_MACAROON_SECRET_KEY=${SYNAPSE_MACAROON_SECRET_KEY}
SYNAPSE_FORM_SECRET=${SYNAPSE_FORM_SECRET}
